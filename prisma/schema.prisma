// schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  AUTHOR
  ADMIN
}

enum PromptStatus {
  PENDING
  PUBLISHED
  REJECTED
}

enum AuthorRequestStatus {
  PENDING
  REJECTED
}

enum Stage {
  DESIGN      // 1. วิเคราะห์ & ออกแบบ (ต้นน้ำ)
  MATERIAL    // 2. สร้างสื่อ & ใบงาน (กลางน้ำ)
  FACILITATE  // 3. จัดกิจกรรมในชั้นเรียน (กลางน้ำ)
  ASSESS      // 4. ประเมิน & ป้อนกลับ (ปลายน้ำ)
  REFLECT     // 5. สะท้อนคิด & ต่อยอด (ปลายน้ำ)
}

enum Subject {
  THAI
  SCIENCE
  SOCIAL
  CROSS
}

enum SkillFocus {
  RL
  CT
  BOTH
}

enum Grade {
  M1
  M2
  M3
  M1_3
}

enum TeachingSubject {
  THAI        // ภาษาไทย
  MATH        // คณิตศาสตร์
  SCIENCE     // วิทยาศาสตร์และเทคโนโลยี
  SOCIAL      // สังคมศึกษาฯ
  HEALTH_PE   // สุขศึกษาและพลศึกษา
  ART         // ศิลปะ
  CAREER_TECH // การงานอาชีพ
  FOREIGN_LANG // ภาษาต่างประเทศ
  OTHER       // อื่นๆ
}

enum ShowcaseType {
  IMAGE   // อัปโหลดรูปภาพไปยัง MinIO
  LINK    // ลิงก์ภายนอก (Google Drive, Canva, OneDrive)
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  emailVerified        DateTime?
  name                 String?
  image                String?
  googleSub            String?              @unique
  role                 Role                 @default(USER)
  authorRequestStatus  AuthorRequestStatus?
  slug                 String?              @unique // URL ของ profile เช่น /u/somchai
  bio                  String?              @db.VarChar(300)
  school               String?              @db.VarChar(200)
  teachingSubjects     TeachingSubject[]
  createdAt            DateTime             @default(now())
  lastLoginAt          DateTime?

  loginLogs        LoginLog[]
  ratings          Rating[]
  promptsCreated   Prompt[]         @relation("PromptCreatedBy")
  showcases        Showcase[]       @relation("ShowcaseCreatedBy")
  showcaseRatings  ShowcaseRating[]

  // NextAuth required relations
  accounts       Account[]
  sessions       Session[]
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loginAt   DateTime @default(now())
  ipAddress String?
  userAgent String?

  @@index([userId])
}

model Prompt {
  id            String     @id @default(cuid())
  title         String
  text          String     @db.Text
  stage         Stage
  subject       Subject
  skill         SkillFocus
  grade         Grade
  status        PromptStatus @default(PUBLISHED)
  copyCount     Int          @default(0) // เพิ่มทุกครั้งที่ user login กดคัดลอกสำเร็จ — core field ของ MVP
  createdById   String
  createdBy     User       @relation("PromptCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  ratings       Rating[]
  showcases     Showcase[]

  @@index([stage])
  @@index([subject])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  value     Int      // 1-5, บังคับกรอก
  comment   String?  @db.VarChar(200) // ความเห็นสั้น ๆ ประกอบดาว — optional
  isHidden  Boolean  @default(false)  // admin soft-hide คอมเมนต์ที่ไม่เหมาะสม (ดาวยังมีผลเหมือนเดิม)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([userId, promptId])
  @@index([promptId])
}

model Showcase {
  id          String       @id @default(cuid())
  promptId    String
  authorId    String
  title       String
  description String?      @db.VarChar(300)
  type        ShowcaseType
  imageKey    String?      // MinIO object key (สำหรับ IMAGE หรือ thumbnail ของ LINK)
  externalUrl String?      // ต้องมีถ้า type=LINK
  isHidden    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  prompt   Prompt           @relation(fields: [promptId], references: [id], onDelete: Cascade)
  author   User             @relation("ShowcaseCreatedBy", fields: [authorId], references: [id])
  ratings  ShowcaseRating[]

  @@index([promptId])
  @@index([authorId])
}

model ShowcaseRating {
  id         String   @id @default(cuid())
  userId     String
  showcaseId String
  value      Int      // 1-5
  comment    String?  @db.VarChar(200)
  isHidden   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  showcase Showcase @relation(fields: [showcaseId], references: [id], onDelete: Cascade)

  @@unique([userId, showcaseId])
  @@index([showcaseId])
}

// ----- NextAuth.js required models (Prisma Adapter) -----
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}